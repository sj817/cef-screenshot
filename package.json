{
  "name": "cef-screenshot",
  "version": "0.3.1",
  "description": "基于 CEF 离屏渲染的超低内存网页截图工具",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "setup": "node --experimental-strip-types scripts/setup.ts",
    "setup:cpp": "node --experimental-strip-types scripts/setup.ts --cpp-only",
    "build": "napi build --platform --release --js false && tsc -p tsconfig.build.json",
    "build:debug": "napi build --platform --js false && tsc -p tsconfig.build.json",
    "pack:runtime": "node --experimental-strip-types scripts/pack.ts",
    "test": "node --experimental-strip-types test/test.ts",
    "test:concurrent": "node --experimental-strip-types test/test-concurrent.ts",
    "test:selector": "node --experimental-strip-types test/test-selector.ts",
    "test:options": "node --experimental-strip-types test/test-options.ts",
    "benchmark": "node --experimental-strip-types benchmark/compare.ts",
    "interactive": "node --experimental-strip-types scripts/interactive.ts",
    "typecheck": "tsc --noEmit",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release",
    "version": "napi version"
  },
  "napi": {
    "binaryName": "cef-screenshot",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "armv7-unknown-linux-gnueabihf",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.0",
    "@types/node": "^22.19.15",
    "puppeteer": "^24.40.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.6.0",
    "pnpm": ">=9"
  },
  "license": "MIT"
}
