{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "index.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "benchmark/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "target",
    "dist",
    "third_party",
    "cef-helper",
    "packages"
  ]
}
